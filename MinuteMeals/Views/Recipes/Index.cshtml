@model IEnumerable<MinuteMeals.Models.Recipe>
@{
    ViewData["Title"] = "Recipes Management";
}

<h2>Recipes Management</h2>

<table class="table table-striped table-bordered mt-3">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Cooking Time</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var recipe in Model)
        {
            <partial name="RecipeRowPartial" model="recipe" />
        }
    </tbody>
</table>
