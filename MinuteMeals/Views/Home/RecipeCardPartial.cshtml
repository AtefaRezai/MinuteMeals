@model MinuteMeals.Models.Recipe

<div class="col-md-4 mb-3">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title">
                <a asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-dark">
                    @Model.Name
                </a>
            </h5>
            <p class="card-text">
                Cooking Time: @Model.CookingTimeInMinutes minutes
            </p>
        </div>
    </div>
</div>
