@model MinuteMeals.Models.Recipe

@{
    ViewData["Title"] = "Details";
}

<div class="card shadow">
    <div class="card-body">
        <h2>@Model.Name</h2>
        <p><strong>Cooking Time:</strong> @Model.CookingTimeInMinutes minutes</p>

        <hr />

        <h4>Ingredients</h4>
        <p>@Model.Ingredients</p>

        <h4>Steps</h4>
        <p>@Model.Steps</p>

        <a asp-action="Index" class="btn btn-secondary mt-3">Back</a>
    </div>
</div>